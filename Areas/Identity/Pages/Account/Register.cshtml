@page
@model RegisterModel
@{
    ViewData["Title"] = "إنشاء حساب";
}

<div class="auth-page">
    <div class="auth-card glass-card">
        <div class="auth-brand">
            <div class="brand-badge">XP</div>
            <h1 class="auth-title">إنشاء حساب</h1>
            <p class="auth-subtitle">أنشئ حسابًا احترافيًا لرفع وتعديل ملفاتك</p>
        </div>

        <form asp-route-returnUrl="@Model.ReturnUrl" method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="Input.FullName" class="form-label">الاسم الكامل</label>
                <input asp-for="Input.FullName" class="form-control auth-input" />
                <span asp-validation-for="Input.FullName" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Input.UserName" class="form-label">اسم المستخدم</label>
                <input asp-for="Input.UserName" class="form-control auth-input" />
                <span asp-validation-for="Input.UserName" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Input.Email" class="form-label">البريد الإلكتروني</label>
                <input asp-for="Input.Email" class="form-control auth-input" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Input.Password" class="form-label">كلمة المرور</label>
                <input asp-for="Input.Password" class="form-control auth-input" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="Input.ConfirmPassword" class="form-label">تأكيد كلمة المرور</label>
                <input asp-for="Input.ConfirmPassword" class="form-control auth-input" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn auth-btn auth-btn-primary w-100">إنشاء الحساب</button>

            <div class="auth-links">
                <a asp-page="./Login">لديك حساب بالفعل؟ تسجيل الدخول</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    body {
        min-height: 100vh;
        background: radial-gradient(circle at top right, rgba(59,130,246,.18), transparent 30%), radial-gradient(circle at bottom left, rgba(14,165,233,.12), transparent 30%), linear-gradient(135deg, #020617, #0f172a, #111827);
        font-family: "Segoe UI", Tahoma, sans-serif;
    }

    .auth-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 30px 15px;
    }

    .glass-card {
        background: rgba(15, 23, 42, 0.82);
        backdrop-filter: blur(14px);
        border: 1px solid rgba(255,255,255,.08);
    }

    .auth-card {
        width: 100%;
        max-width: 620px;
        border-radius: 28px;
        padding: 42px 34px;
        box-shadow: 0 25px 60px rgba(0,0,0,.30);
    }

    .auth-brand {
        text-align: center;
        margin-bottom: 26px;
    }

    .brand-badge {
        width: 68px;
        height: 68px;
        margin: 0 auto 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 20px;
        background: linear-gradient(135deg, #2563eb, #0ea5e9);
        color: #fff;
        font-size: 24px;
        font-weight: 800;
        box-shadow: 0 12px 24px rgba(37,99,235,.28);
    }

    .auth-title {
        font-size: 40px;
        font-weight: 800;
        text-align: center;
        color: #f8fafc;
        margin-bottom: 10px;
    }

    .auth-subtitle {
        text-align: center;
        color: #94a3b8;
        margin-bottom: 8px;
        font-size: 16px;
    }

    .form-label {
        font-weight: 700;
        color: #e2e8f0;
        margin-bottom: 8px;
    }

    .auth-input {
        min-height: 54px;
        border-radius: 14px;
        border: 1px solid rgba(255,255,255,.08);
        background: rgba(2,6,23,.65);
        color: #f8fafc;
        font-size: 16px;
    }

        .auth-input:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 0.2rem rgba(37,99,235,.15);
            background: rgba(2,6,23,.9);
            color: #fff;
        }

    .auth-btn {
        min-height: 54px;
        border-radius: 14px;
        font-size: 18px;
        font-weight: 700;
    }

    .auth-btn-primary {
        background: linear-gradient(135deg, #2563eb, #1d4ed8, #0ea5e9);
        border: none;
        color: white;
    }

    .auth-links {
        margin-top: 20px;
        text-align: center;
    }

        .auth-links a {
            color: #93c5fd;
            text-decoration: none;
            font-weight: 700;
        }

            .auth-links a:hover {
                text-decoration: underline;
            }
</style>