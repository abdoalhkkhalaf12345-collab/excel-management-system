@page
@model Abdullhak_Khalaf.Areas.Identity.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "إنشاء حساب جديد";
}

<div class="auth-page">
    <div class="auth-card">
        <h1 class="auth-title">إنشاء حساب جديد</h1>
        <p class="auth-subtitle">أنشئ حسابك للبدء باستخدام النظام</p>

        <form method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="Input.Email" class="form-label">البريد الإلكتروني</label>
                <input asp-for="Input.Email" class="form-control auth-input" autocomplete="username" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Input.Password" class="form-label">كلمة المرور</label>
                <input asp-for="Input.Password" type="password" class="form-control auth-input" autocomplete="new-password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="Input.ConfirmPassword" class="form-label">تأكيد كلمة المرور</label>
                <input asp-for="Input.ConfirmPassword" type="password" class="form-control auth-input" autocomplete="new-password" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn auth-btn auth-btn-success w-100">إنشاء الحساب</button>

            <div class="auth-links">
                <a asp-page="./Login">تسجيل الدخول</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    body {
        background: linear-gradient(135deg, #eef4ff, #f8fbff);
        font-family: "Segoe UI", Tahoma, sans-serif;
    }

    .auth-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 30px 15px;
    }

    .auth-card {
        width: 100%;
        max-width: 520px;
        background: #ffffff;
        border-radius: 24px;
        padding: 40px 32px;
        box-shadow: 0 20px 50px rgba(15, 23, 42, 0.12);
        border: 1px solid #e5e7eb;
    }

    .auth-title {
        font-size: 42px;
        font-weight: 800;
        text-align: center;
        color: #0f172a;
        margin-bottom: 10px;
    }

    .auth-subtitle {
        text-align: center;
        color: #64748b;
        margin-bottom: 30px;
        font-size: 16px;
    }

    .form-label {
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 8px;
    }

    .auth-input {
        min-height: 52px;
        border-radius: 14px;
        border: 1px solid #cbd5e1;
        background: #f8fafc;
        font-size: 16px;
    }

        .auth-input:focus {
            border-color: #16a34a;
            box-shadow: 0 0 0 0.2rem rgba(22, 163, 74, 0.15);
            background: #fff;
        }

    .auth-btn {
        min-height: 52px;
        border-radius: 14px;
        font-size: 18px;
        font-weight: 700;
    }

    .auth-btn-success {
        background: linear-gradient(135deg, #16a34a, #15803d);
        border: none;
        color: white;
    }

        .auth-btn-success:hover {
            opacity: 0.95;
        }

    .auth-links {
        margin-top: 20px;
        text-align: center;
    }

        .auth-links a {
            color: #1d4ed8;
            text-decoration: none;
            font-weight: 700;
        }

            .auth-links a:hover {
                text-decoration: underline;
            }
</style>