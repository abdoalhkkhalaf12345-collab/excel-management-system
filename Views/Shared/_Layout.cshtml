<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Excel Pro Manager</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
            :root {
                --bg-1: #020617;
                --bg-2: #0f172a;
                --bg-3: #111827;
                --card: rgba(15, 23, 42, 0.82);
                --card-border: rgba(255,255,255,.08);
                --text-main: #f8fafc;
                --text-soft: #cbd5e1;
                --text-muted: #94a3b8;
                --primary: #2563eb;
                --primary-2: #0ea5e9;
            }

            html, body {
                min-height: 100%;
            }

            body {
                margin: 0;
                background: radial-gradient(circle at top right, rgba(59,130,246,.10), transparent 30%), radial-gradient(circle at bottom left, rgba(14,165,233,.08), transparent 30%), linear-gradient(135deg, var(--bg-1), var(--bg-2), var(--bg-3));
                color: var(--text-main);
                font-family: "Segoe UI", Tahoma, sans-serif;
            }

            .main-navbar {
                background: rgba(2,6,23,.90);
                backdrop-filter: blur(12px);
                border-bottom: 1px solid rgba(255,255,255,.06);
                box-shadow: 0 10px 25px rgba(0,0,0,.18);
            }

                .main-navbar .navbar-brand,
                .main-navbar .nav-link,
                .main-navbar .navbar-text {
                    color: #f8fafc !important;
                    font-weight: 700;
                }

                    .main-navbar .nav-link:hover {
                        color: #93c5fd !important;
                    }

            .navbar-brand {
                font-size: 1.6rem;
            }

            main {
                min-height: calc(100vh - 132px);
                padding-top: 30px;
                padding-bottom: 40px;
            }

            .main-page-wrapper {
                width: 100%;
                max-width: 1400px;
                margin: 0 auto;
                padding-left: 18px;
                padding-right: 18px;
            }

            footer {
                background: rgba(2,6,23,.92);
                border-top: 1px solid rgba(255,255,255,.06);
                padding: 14px 0;
                color: var(--text-muted);
                text-align: center;
            }

            .btn,
            .form-control {
                box-shadow: none !important;
            }

            .form-control {
                direction: rtl;
                text-align: right;
            }

                .form-control::placeholder {
                    color: #94a3b8;
                    opacity: 1;
                }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg main-navbar">
            <div class="container-fluid px-3 px-md-4">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">Excel Pro Manager</a>

                <button class="navbar-toggler bg-light" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">الرئيسية</a>
                        </li>
                    </ul>

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <main>
        <div class="main-page-wrapper">
            @RenderBody()
        </div>
    </main>

    <footer>
        نظام احترافي لإدارة ملفات Excel و CSV
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>