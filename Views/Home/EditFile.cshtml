@model Abdullhak_Khalaf.Models.ExcelEditorViewModel

@{
    ViewData["Title"] = "تعديل الملف";
}

<div class="editor-page" data-file-id="@Model.FileId" data-sheet-name="@Model.SheetName">
    <div class="editor-header-card">
        <div>
            <h1>تعديل الملف</h1>
            <p>اسم الملف: <strong>@Model.OriginalFileName</strong></p>
            <p>النوع: <strong>@Model.FileType.ToUpper()</strong></p>
            <p>المصدر: <strong>@(Model.IsCsv ? "CSV" : "Excel")</strong></p>
            <p>اسم الشيت: <strong>@Model.SheetName</strong></p>
        </div>

        <div class="editor-actions-top">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light">رجوع</a>
            <button type="button" class="btn btn-success" id="saveBtn">حفظ التعديلات</button>
            <button type="button" class="btn btn-primary" id="addRowBtn">إضافة صف</button>
            <button type="button" class="btn btn-dark" id="addColBtn">إضافة عمود</button>
        </div>
    </div>

    <div class="editor-table-card">
        <div class="editor-tools">
            <input type="text" id="searchInTable" class="form-control search-input" placeholder="ابحث داخل الجدول..." />
        </div>

        <div class="table-responsive">
            <table class="table premium-table align-middle" id="excelTable">
                <thead>
                    <tr id="headerRow">
                        @for (int i = 0; i < Model.Headers.Count; i++)
                        {
                            <th>
                                <input type="text" class="form-control table-input header-input" value="@Model.Headers[i]" />
                            </th>
                        }
                        <th class="action-col">إجراء</th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    @for (int r = 0; r < Model.Rows.Count; r++)
                    {
                        <tr>
                            @for (int c = 0; c < Model.Headers.Count; c++)
                            {
                                var cellValue = c < Model.Rows[r].Count ? Model.Rows[r][c] : "";
                                <td>
                                    <input type="text" class="form-control table-input cell-input" value="@cellValue" />
                                </td>
                            }
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-danger remove-row">حذف الصف</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const editorPage = document.querySelector(".editor-page");
            const fileId = parseInt(editorPage.dataset.fileId);
            const sheetName = editorPage.dataset.sheetName || "";

            const tableBody = document.getElementById("tableBody");
            const headerRow = document.getElementById("headerRow");
            const saveBtn = document.getElementById("saveBtn");
            const addRowBtn = document.getElementById("addRowBtn");
            const addColBtn = document.getElementById("addColBtn");
            const searchInput = document.getElementById("searchInTable");

            let autoSaveTimer = null;

            function getColumnCount() {
                return document.querySelectorAll(".header-input").length;
            }

            addRowBtn.addEventListener("click", function () {
                const tr = document.createElement("tr");
                const colCount = getColumnCount();

                let html = "";
                for (let i = 0; i < colCount; i++) {
                    html += '<td><input type="text" class="form-control table-input cell-input" value="" /></td>';
                }

                html += '<td><button type="button" class="btn btn-sm btn-outline-danger remove-row">حذف الصف</button></td>';
                tr.innerHTML = html;
                tableBody.appendChild(tr);
            });

            addColBtn.addEventListener("click", function () {
                const th = document.createElement("th");
                th.innerHTML = '<input type="text" class="form-control table-input header-input" value="عمود جديد" />';
                headerRow.insertBefore(th, headerRow.lastElementChild);

                document.querySelectorAll("#tableBody tr").forEach(function (tr) {
                    const td = document.createElement("td");
                    td.innerHTML = '<input type="text" class="form-control table-input cell-input" value="" />';
                    tr.insertBefore(td, tr.lastElementChild);
                });
            });

            document.addEventListener("click", function (e) {
                if (e.target.classList.contains("remove-row")) {
                    const row = e.target.closest("tr");
                    if (row) row.remove();
                }
            });

            function collectPayload() {
                const headers = [];
                document.querySelectorAll(".header-input").forEach(function (input) {
                    headers.push(input.value.trim());
                });

                const rows = [];
                document.querySelectorAll("#tableBody tr").forEach(function (tr) {
                    const row = [];
                    tr.querySelectorAll(".cell-input").forEach(function (input) {
                        row.push(input.value);
                    });
                    rows.push(row);
                });

                return {
                    fileId: fileId,
                    sheetName: sheetName,
                    headers: headers,
                    rows: rows
                };
            }

            function saveNow(showMessage = true) {
                const payload = collectPayload();

                fetch("/Home/SaveEditedFile", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify(payload)
                })
                .then(function (res) { return res.json(); })
                .then(function (result) {
                    if (showMessage) {
                        if (result.success) {
                            showToast(result.message || "تم الحفظ بنجاح", "success");
                        } else {
                            showToast(result.message || "فشل الحفظ", "error");
                        }
                    }
                })
                .catch(function () {
                    if (showMessage) {
                        showToast("حدث خطأ أثناء حفظ الملف", "error");
                    }
                });
            }

            saveBtn.addEventListener("click", function () {
                saveNow(true);
            });

            document.addEventListener("input", function (e) {
                if (e.target.classList.contains("cell-input") || e.target.classList.contains("header-input")) {
                    clearTimeout(autoSaveTimer);
                    autoSaveTimer = setTimeout(function () {
                        saveNow(false);
                    }, 1200);
                }
            });

            searchInput.addEventListener("input", function () {
                const keyword = this.value.trim().toLowerCase();

                document.querySelectorAll("#tableBody tr").forEach(function (tr) {
                    const text = tr.innerText.toLowerCase();
                    tr.style.display = text.includes(keyword) ? "" : "none";
                });
            });

            function showToast(message, type) {
                const toast = document.createElement("div");
                toast.className = "edit-toast " + type;
                toast.textContent = message;
                document.body.appendChild(toast);

                setTimeout(function () {
                    toast.style.opacity = "0";
                    setTimeout(function () {
                        toast.remove();
                    }, 400);
                }, 2500);
            }
        })();
    </script>
}

<style>
    body {
        background:
            radial-gradient(circle at top right, rgba(59,130,246,.10), transparent 30%),
            radial-gradient(circle at bottom left, rgba(14,165,233,.08), transparent 30%),
            #0f172a;
        font-family: "Segoe UI", Tahoma, sans-serif;
    }

    .editor-page {
        padding: 24px;
        color: #e2e8f0;
    }

    .editor-header-card,
    .editor-table-card {
        background: rgba(15,23,42,.88);
        border-radius: 20px;
        padding: 24px;
        box-shadow: 0 16px 32px rgba(0,0,0,.20);
        border: 1px solid rgba(255,255,255,.08);
        margin-bottom: 24px;
    }

    .editor-header-card {
        display: flex;
        justify-content: space-between;
        gap: 20px;
        flex-wrap: wrap;
        align-items: center;
    }

    .editor-header-card h1 {
        margin-bottom: 10px;
        color: #f8fafc;
        font-weight: 800;
    }

    .editor-header-card p {
        color: #cbd5e1;
        margin-bottom: 6px;
    }

    .editor-actions-top {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .editor-tools {
        margin-bottom: 16px;
    }

    .search-input {
        background: #0f172a;
        color: #f8fafc;
        border: 1px solid rgba(255,255,255,.10);
        border-radius: 12px;
        min-height: 48px;
    }

    .premium-table {
        min-width: 1000px;
        border-collapse: separate;
        border-spacing: 0;
        overflow: hidden;
    }

    .premium-table thead th {
        background: linear-gradient(180deg, #1e293b, #0f172a);
        color: #f8fafc;
        border: 1px solid rgba(255,255,255,.08);
        text-align: center;
        vertical-align: middle;
    }

    .premium-table tbody td {
        background: rgba(15,23,42,.72);
        border: 1px solid rgba(255,255,255,.06);
        vertical-align: middle;
    }

    .premium-table tbody tr:hover td {
        background: rgba(30,41,59,.95);
    }

    .table-input {
        min-width: 140px;
        border-radius: 10px;
        background: #111827;
        color: #f8fafc;
        border: 1px solid rgba(255,255,255,.10);
    }

    .table-input:focus {
        background: #0f172a;
        color: #fff;
        border-color: #60a5fa;
        box-shadow: 0 0 0 0.2rem rgba(96,165,250,.12);
    }

    .action-col {
        min-width: 120px;
    }

    .edit-toast {
        position: fixed;
        top: 20px;
        right: 20px;
        color: #fff;
        padding: 14px 18px;
        border-radius: 12px;
        z-index: 99999;
        box-shadow: 0 12px 20px rgba(0, 0, 0, 0.18);
        transition: .3s;
    }

    .edit-toast.success { background: #16a34a; }
    .edit-toast.error { background: #dc2626; }
</style>